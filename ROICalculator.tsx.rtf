          <h2 className="text-4xl font-bold text-gray-900 mb-4">What is a missed lead costing your business?</h2>\
        </motion.div>\
\
        <motion.div initial=\{\{ opacity: 0, y: 20 \}\} whileInView=\{\{ opacity: 1, y: 0 \}\} className="bg-white rounded-2xl shadow-xl border p-8">\
          <div className="grid md:grid-cols-3 gap-8 mb-12">\
