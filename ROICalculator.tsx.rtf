            </div>\
            <div>\
              <label className="block text-sm font-medium text-gray-700 mb-2">Response time (hours)</label>\
              <input type="range" min="1" max="24" value=\{responseTime\} onChange=\{(e) => setResponseTime(Number(e.target.value))\} className="w-full accent-blue-600" />\
              <div className="text-2xl font-bold text-blue-600 mt-2">\{responseTime\}h</div>\
            </div>\
          </div>\
\
          <div className="bg-gray-50 rounded-xl p-8 mb-8">\
